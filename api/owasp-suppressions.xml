<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check suppressions for kip-platform/api
  =========================================================
  Add entries here ONLY for confirmed false-positives where the scanner's CPE
  matching is incorrect AND no patched version exists yet. Each suppression MUST include:
    - A justification comment explaining why it is a false positive or accepted risk
    - An expiry date (until="...") so it is revisited periodically

  Prefer fixing CVEs via version upgrades in gradle/libs.versions.toml over suppressing.

  Reference: https://jeremylong.github.io/DependencyCheck/general/suppression.html
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        FALSE POSITIVE: CVE-2023-36415 and CVE-2024-35255 are matched against azure-identity via an incorrect CPE
        (cpe:2.3:a:microsoft:azure_identity_sdk / azure_sdk_for_java). The CVE advisory applies to older Azure
        Identity SDK versions <= 1.10.x. azure-identity 1.18.2 is not affected — confirmed by GitHub Advisory
        Database which reports no known CVEs for com.azure:azure-identity@1.18.2.
        Expiry: 2026-10-22 — re-evaluate if a newer advisory changes the affected range.
    -->
    <suppress until="2026-10-22Z">
        <notes>False positive CPE match for azure-identity 1.18.2. CVE-2023-36415 and CVE-2024-35255 do not
            affect this version per GitHub Advisory Database.</notes>
        <packageUrl regex="true">^pkg:maven/com\.azure/azure\-identity@1\.18\.2$</packageUrl>
        <cve>CVE-2023-36415</cve>
    </suppress>
    <suppress until="2026-10-22Z">
        <notes>False positive CPE match for azure-identity 1.18.2. CVE-2024-35255 does not affect this version
            per GitHub Advisory Database. The msal4j transitive dependency CVE-2024-35255 is also a false
            positive as msal4j 1.23.1 is not in the affected range.</notes>
        <packageUrl regex="true">^pkg:maven/com\.azure/azure\-identity@1\.18\.2$</packageUrl>
        <cve>CVE-2024-35255</cve>
    </suppress>
    <suppress until="2026-10-22Z">
        <notes>False positive CPE match for msal4j 1.23.1. CVE-2024-35255 does not affect this version
            per GitHub Advisory Database.</notes>
        <packageUrl regex="true">^pkg:maven/com\.microsoft\.azure/msal4j@.*$</packageUrl>
        <cve>CVE-2024-35255</cve>
    </suppress>

</suppressions>