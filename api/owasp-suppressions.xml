<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check suppressions for kip-platform/api
  =========================================================
  Reference: https://jeremylong.github.io/DependencyCheck/general/suppression.html
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- CVE-2025-48734: commons-beanutils deserialization vulnerability.
         No fixed version exists on Maven Central as of 2026-04-21 (latest is 1.9.4).
         Transitive dep via commons-validator/checkstyle — not used directly.
         We do not deserialize untrusted data through BeanUtils.
         Remove when 1.9.5+ is released by Apache. -->
    <suppress until="2027-01-01Z">
        <notes>No patched version released. Transitive via commons-validator/checkstyle.
            Not exploitable — no untrusted deserialization in our codebase.</notes>
        <packageUrl regex="true">^pkg:maven/commons\-beanutils/commons\-beanutils@.*$</packageUrl>
        <cve>CVE-2025-48734</cve>
    </suppress>

    <!-- CVE-2023-36415: Fixed in azure-identity 1.11.4. We use 1.15.4 (patched).
         Scanner false-positive due to overly broad NVD CPE range. -->
    <suppress until="2027-01-01Z">
        <notes>CVE-2023-36415 fixed in azure-identity 1.11.4. Current version 1.15.4 is patched.
            NVD CPE match is a false positive — version constraint in NVD is incorrect.</notes>
        <packageUrl regex="true">^pkg:maven/com\.azure/azure\-identity@.*$</packageUrl>
        <cve>CVE-2023-36415</cve>
    </suppress>

    <!-- CVE-2024-35255: Fixed in azure-identity 1.15.1 and msal4j 1.15.1+.
         We use azure-identity 1.15.4 which includes the fix. Scanner false-positive. -->
    <suppress until="2027-01-01Z">
        <notes>CVE-2024-35255 fixed in azure-identity 1.15.1. Current version 1.15.4 is patched.
            Also suppressed on msal4j (transitive) for same reason.</notes>
        <packageUrl regex="true">^pkg:maven/com\.azure/azure\-identity@.*$</packageUrl>
        <cve>CVE-2024-35255</cve>
    </suppress>

    <suppress until="2027-01-01Z">
        <notes>CVE-2024-35255: msal4j is transitive via azure-identity 1.15.4 which is patched.</notes>
        <packageUrl regex="true">^pkg:maven/com\.microsoft\.azure/msal4j@.*$</packageUrl>
        <cve>CVE-2024-35255</cve>
    </suppress>

    <!-- CVE-2025-67030: plexus-utils transitive via Gradle build plugins (not runtime).
         We force plexus-utils:4.0.2 which is the latest release. The NVD CPE range
         incorrectly includes 4.0.2 — the fix was delivered in 4.0.1. False positive. -->
    <suppress until="2027-01-01Z">
        <notes>CVE-2025-67030: plexus-utils 4.0.2 is the latest release and post-fix version.
            NVD CPE range incorrectly flags it. Transitive via Gradle plugins only — not
            present in the runtime application classpath.</notes>
        <packageUrl regex="true">^pkg:maven/org\.codehaus\.plexus/plexus\-utils@.*$</packageUrl>
        <cve>CVE-2025-67030</cve>
    </suppress>

</suppressions>