# ============================================================
# Gradle
# ============================================================
.gradle/
build/
gradle-app.setting

# ============================================================
# Java compiled output
# ============================================================
*.class
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*
# Gradle wrapper JAR must be committed — negation must come AFTER *.jar
!gradle-wrapper.jar

# ============================================================
# Spring Boot / Secrets
# Patterns without a leading '/' match at any depth — covers
# src/main/resources/ in all sub-modules of this monorepo.
# ============================================================
.env
*.env
*.pem
*.p12
*.jks
*.keystore

# ============================================================
# IntelliJ IDEA
# Ignore the entire .idea directory; individual workspace files
# are machine-specific and should never be committed.
# ============================================================
.idea/
*.iml
*.iws
*.ipr
out/

# ============================================================
# Eclipse / Spring Tool Suite (STS)
# ============================================================
.classpath
.project
.settings/
.springBeans
.sts4-cache/
.factorypath
bin/

# ============================================================
# NetBeans
# ============================================================
**/nbproject/private/
nbbuild/
nbdist/
.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ============================================================
# VS Code
# ============================================================
.vscode/

# ============================================================
# Logs
# ============================================================
*.log
logs/
spring.log

# ============================================================
# Docker (local overrides only)
# ============================================================
docker-compose.override.yml
.dockerenv

# ============================================================
