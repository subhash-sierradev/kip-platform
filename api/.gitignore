# ============================================================
# Maven
# Based on: https://github.com/github/gitignore/blob/main/Java.gitignore
# NOTE (monorepo): patterns without a leading '/' match at any depth,
# so target/, *.class, etc. cover all sub-modules automatically.
# Patterns WITH a '/' in the middle are root-anchored — use **/ prefix
# so they also match inside each sub-module directory.
# ============================================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
**/.mvn/timing.properties

# Keep Maven wrapper JARs in ALL modules so CI can bootstrap without pre-installed Maven
!**/.mvn/wrapper/maven-wrapper.jar

# ============================================================
# Java compiled output
# ============================================================
*.class
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# ============================================================
# Spring Boot / Secrets
# Patterns without a leading '/' match at any depth — covers
# src/main/resources/ in all sub-modules of this monorepo.
# ============================================================
.env
*.env
*.pem
*.p12
*.jks
*.keystore

# ============================================================
# IntelliJ IDEA
# Ignore the entire .idea directory; individual workspace files
# are machine-specific and should never be committed.
# ============================================================
.idea/
*.iml
*.iws
*.ipr
out/

# ============================================================
# Eclipse / Spring Tool Suite (STS)
# ============================================================
.classpath
.project
.settings/
.springBeans
.sts4-cache/
.factorypath
bin/

# ============================================================
# NetBeans
# ============================================================
**/nbproject/private/
nbbuild/
nbdist/
.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ============================================================
# VS Code
# ============================================================
.vscode/

# ============================================================
# Logs
# ============================================================
*.log
logs/
spring.log

# ============================================================
# Docker (local overrides only)
# ============================================================
docker-compose.override.yml
.dockerenv

# ============================================================
# OS-generated files
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
