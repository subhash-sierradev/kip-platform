{
  "name": "kip-web",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation vite --host 0.0.0.0",
    "dev:sandbox": "cross-env NODE_OPTIONS=--no-deprecation vite --mode sandbox --host 0.0.0.0",
    "build": "npm run audit:check && npm run format:check && vue-tsc && npm run test:run && npm run build:bundle",
    "build:ci": "npm run audit:check && npm run format:check && cross-env NODE_OPTIONS='--max-old-space-size=4096' vue-tsc && npm run test:run && npm run build:bundle",
    "build:bundle": "vite build --mode production",
    "build:check": "npm run format:check && vue-tsc --noEmit && npm run test:run && vite build --mode development --logLevel error",
    "build:sandbox": "npm run format:check && vue-tsc && vite build --mode sandbox",
    "build:deploy": "npm install && npm run build:sandbox && npx serve dist -s -p 8084 --no-clipboard",
    "build:deploy:http": "npm install && npm run build:sandbox && npx http-server dist -p 8084 -c-1 --cors",
    "build:deploy:full": "npm install && npm run validate:fix && npm run build:sandbox && npx http-server dist -p 8084 -c-1 --cors",
    "build:docker": "vue-tsc && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,vue}\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix",
    "lint:check": "eslint \"src/**/*.{ts,vue}\" --max-warnings 0",
    "lint:strict": "eslint \"src/**/*.{ts,vue}\" --max-warnings 0 --report-unused-disable-directives",
    "lint:cache": "eslint \"src/**/*.{ts,vue}\" --cache --max-warnings 0",
    "format": "prettier --write \"src/**/*.{js,ts,vue,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,css,scss,json}\"",
    "type-check": "vue-tsc --noEmit --skipLibCheck",
    "type-check:watch": "vue-tsc --noEmit --skipLibCheck --watch",
    "type-check:strict": "vue-tsc --noEmit --strict",
    "test": "vitest --config vitest.config.ts",
    "test:unit": "cross-env VITEST_SUITE=unit vitest run --config vitest.config.ts",
    "test:integration": "cross-env VITEST_SUITE=integration vitest run --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:coverage": "cross-env VITEST_SUITE=all vitest run --coverage --config vitest.config.ts",
    "test:coverage:check": "vitest run --coverage --config vitest.config.ts --reporter=text-summary",
    "test:coverage:enforce": "node scripts/test-coverage-enforce.js",
    "coverage:verify": "node scripts/coverage-verify.js",
    "test:watch": "cross-env VITEST_SUITE=unit vitest --watch --config vitest.config.ts",
    "test:ui": "vitest --ui --config vitest.config.ts",
    "validate": "npm run format:check && npm run type-check && npm run lint:strict && npm run test:run",
    "validate:fix": "npm run format && npm run type-check && npm run lint:fix && npm run test:coverage:enforce",
    "validate:coverage": "npm run format:check && npm run type-check && npm run lint:strict && npm run test:coverage:enforce && echo \"All validation checks with enforced coverage completed!\"",
    "validate:coverage:ci": "npm run format:check && npm run type-check && npm run lint:strict && npm run test:coverage:enforce",
    "ci": "npm run audit:check && npm run format:check && npm run lint:strict && npm run type-check && npm run test:coverage:enforce && npm run build:bundle",
    "ci:no-format": "npm run lint:strict && npm run type-check && npm run test:coverage:enforce && npm run build:bundle",
    "validate:quick": "npm run lint:check && npm run test:run && echo \"Quick validation checks passed!\"",
    "audit:check": "npm audit --audit-level=high",
    "validate:strict": "npm run format:check && npm run type-check:strict && npm run lint:strict && npm run test:run && echo \"Strict validation checks passed!\"",
    "check-all": "npm run validate:strict",
    "generate:api": "openapi --input ./openapi.yaml --output ./src/api/generated --client axios",
    "version:bump": "node ../scripts/version-manager.js bump",
    "version:current": "node ../scripts/version-manager.js current",
    "version:major": "node ../scripts/version-manager.js bump major",
    "version:minor": "node ../scripts/version-manager.js bump minor",
    "version:patch": "node ../scripts/version-manager.js bump patch",
    "version:tags": "node ../scripts/version-manager.js tags"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "axios": "^1.13.2",
    "cron-validator": "^1.4.0",
    "cronstrue": "^3.14.0",
    "devextreme": "^25.2.5",
    "devextreme-exceljs-fork": "^4.4.6",
    "devextreme-vue": "^25.2.5",
    "file-saver": "^2.0.5",
    "keycloak-js": "^26.2.0",
    "lucide-vue-next": "^0.553.0",
    "luxon": "^3.7.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/file-saver": "^2.0.7",
    "@types/lodash": "^4.17.21",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.9",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^7.0.3",
    "devextreme-themebuilder": "^25.2.5",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "eslint-plugin-vue": "^9.33.0",
    "fast-deep-equal": "^3.1.3",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "^3.8.2",
    "typescript": "^5.7.2",
    "vite": "^7.3.2",
    "vitest": "^4.0.9",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "brace-expansion": "^5.0.5",
    "flatted": "^3.4.2",
    "glob": "^13.0.6",
    "handlebars": "^4.7.9",
    "immutable": "^4.3.8",
    "lodash.isequal": "npm:fast-deep-equal@^3.1.3",
    "minimatch": "^10.2.4",
    "picomatch": "^4.0.4",
    "rollup": "^4.59.0",
    "@eslint/config-array": "^0.23.2",
    "@eslint/eslintrc": "^3.3.4",
    "follow-redirects": "^1.16.0"
  }
}
